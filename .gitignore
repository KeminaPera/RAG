# ================ Runtime Generated Files ================
# Logs - auto-generated during runtime
logs/
*.log

# Uploaded files - temporary user files
uploads/

# Data storage - auto-created during runtime
data/

# Python cache - auto-generated
__pycache__/
*.pyc
*.pyo
*.pyd

# ================ Local Configuration ================
# Environment variables - contains sensitive info (API keys)
.env

# VS Code settings - personal dev environment
.vscode/

# ================ Virtual Environments ================
# Python virtual environments - should be created by user
.venv/
venv/

# ================ Model Files (Optional) ================
# BGE embedding model - large size (~1GB), download via script
# Uncomment below to exclude from git
# bge-small-zh-v1.5/

# BGE reranker model - large size (~1.5GB), download via script
# Uncomment below to exclude from git
# bge-reranker-base/

# ================ OS Files ================
.DS_Store
Thumbs.db

# ================ Other ================
*.swp
*.bak